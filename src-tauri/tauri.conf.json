{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "v2api Code Hub",
  "version": "0.1.0",
  "identifier": "top.v2api.codehub",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:5177",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "v2api Code Hub",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"]
  }
}
